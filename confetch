#!/bin/sh

# This fetch never lies, so you should always trust it.
# No need to edit this file unless yuore STUPID and want it to break.

version="version 1.6"

bold=$(printf '\033[1m')
reset=$(printf '\033[0m')

black=$(printf '\033[0;30m')
white=$(printf '\033[37m')

purple=$(printf '\033[35m')
blue=$(printf '\033[34m')
cyan=$(printf '\033[36m')
green=$(printf '\033[32m')
yellow=$(printf '\033[33m')
red=$(printf '\033[31m')

brightred=$(printf '\033[0;91m')

# decides what modules are in the output. possible options are:
	# title wm kernel shell cpu gpu ram packages terminal uptime distro
# the order changes depending on this aswell just so yk
enabled="
title 
distro 
wm 
shell 
kernel 
packages 
uptime 
terminal 
ram 
cpu 
gpu"
# actually no need to take anyhting out of $enabled,
# just add what you want to remove into $disabled
disabled="
"

# these are for the 2 different thinigies colours
# keep as auto for automatic colouring according to your distro
keycolour="auto"
accentcolour="auto"

# gets your distro. Needed before logooption
. /etc/os-release
distro=$PRETTY_NAME
distroShort=$NAME

# this is for changing the logo
# for a list of logos, use "confetch -h logo"
# i dont plan on making logos for forks unless i decide otherwise.
# this includes distros like mint, artix, pop, cachy, zorin, endeavor, etc.
logooption="$distro"

# past here is where the ugly ugly magic happens. Do NOT go further unless youre me.
# when writing this, only me and god knew what i was writing. Now only i know.

hostname=$(cat /etc/hostname)
lineCount=0
asciiLineCount=0

addLine() {
    lineCount=$((lineCount + 1))
    eval "line_$lineCount=\$1"
}

asciiAddLine() {
	asciiLineCount=$((asciiLineCount + 1))
	eval "ascii_$asciiLineCount=\$1"
}

colouroption() {
    case "$2" in
        red)    eval "$1=\$red" ;;
        blue)   eval "$1=\$blue" ;;
        green)  eval "$1=\$green" ;;
        yellow) eval "$1=\$yellow" ;;
        cyan)   eval "$1=\$cyan" ;;
        purple) eval "$1=\$purple" ;;
        white)  eval "$1=\$white" ;;
        black)  eval "$1=\$black" ;;
        *)
            echo "whats that colour: '$2'?"
            exit 1
            ;;
    esac
}

setAutoColour() {
    [ "$keycolour" = "auto" ] && keycolour=$1
    [ "$accentcolour" = "auto" ] && accentcolour=$2
}

randomlogo() {
	read -r up _ < /proc/uptime
	num=$(( ${up%%.*} % 21 ))

	case "$num" in
    	0) logooption="tux" ;;
	    1) logooption="debian" ;;
	    2) logooption="void" ;;
	    3) logooption="arch" ;;
	    4) logooption="gentoo" ;;
    	5) logooption="fedora" ;;
	    6) logooption="nix" ;;
	    7) logooption="alpine" ;;
	    8) logooption="dragonfly" ;;
	    9) logooption="suse" ;;
	    10) logooption="netbsd" ;;
	    11) logooption="freebsd" ;;
	    12) logooption="openbsd" ;;
	    13) logooption="plan9" ;;
	    14) logooption="gnu" ;;
	    15) logooption="guix" ;;
	    16) logooption="crux" ;;
	    17) logooption="exherbo" ;;
	    18) logooption="nerv" ;;
	    19) logooption="seele" ;;
	    20) logooption="navi" ;;
    	*) logooption="trash" ;;
	esac
}

helpoptions() {
	case "$1" in
		logo)
			echo "  logo options:"
			echo "    tux, debian, nix, void, arch, fedora, freebsd,"
			echo "    alpine, slackware, dragonfly, suse, netbsd,"
			echo "    openbsd, plan9, gentoo, gnu, guix, crux, exherbo,"
			echo "    nerv, seele, navi, and trash (fallback)"
			;;
		accent)
			echo "  accent options:"
			echo "    white, purple, blue, cyan, green, yellow, red"
			;;
		key)
			echo "  key options:"
			echo "    white, purple, blue, cyan, green, yellow, red"
			;;
		key2)
			echo "  key2 options:"
			echo "    white, purple, blue, cyan, green, yellow, red"
			;;
		version)
			echo "  nothing to help with... what??"
			echo "    are you stupid?"
			;;
		larp)
			echo "  larp options:"
			echo "    with logos: everything that --logo has"
			echo "    ^^ except for the non distros like seele or nerv"
			echo "    without correct logos: anything lol"
			;;
		confused)
			echo "  i get that youre a lil confused"
			echo "    but this doesnt have options"
			;;
		shorter)
			echo "  no options buddy.."
			echo "    will make a separate module flag in the future"
			;;
		*)
			echo "  what? Wtf do you need help with??"
			;;
	esac
}

while [ $# -gt 0 ]; do
	case "$1" in
		--version|-v)
			echo "$version"
			exit 0
			;;
		--logo|-l)
			logooption="$2"
			shift 2
			;;
		--key|-k)
			colouroption keycolour "$2"
			shift 2
			;;
		--accent|-a)
			colouroption accentcolour "$2"
			shift 2
			;;
		--larp|-L)
			logooption="$2"
			distroShort="$2"
			distro="$2"
			shift 2
			;;
		--confused|-C)
			randomlogo
			shift
			;;
		--shorter|-s)
			# how i usually run this (yes, i use this instead of fastfetch)
			disabled="cpu gpu ram terminal"
			shift
			;;
		--help|-h)
			cat <<EOF
			
  Usage: confetch [options]

    -h, --help FLAG       | helps you out
    -v, --version         | prints the version
    -l, --logo NAME       | well wtf do you THINK it does, huh??
    -a, --accent COLOUR   | changes your accent irl
    -k, --key COLOUR      | changes your house keys
    -C, --confused        | confuses you
    -s, --shorter         | gets rid of a few modules
    -L. --larp NAME       | sudo W opsec. Larpity larp

EOF
			helpoptions "$2"
			echo
			exit 0
			;;
		*)
			echo "that isnt a command buddy: $1"
			exit 1
			;;
	esac
done

