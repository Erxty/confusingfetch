i=2

printf "%s\n" "$(eval "echo \"\$line_1\"")"

while [ "$i" -le "$lineCount" ] || [ "$((i - 1))" -le "$asciiLineCount" ]; do
    logo_line=$((i - 1))

    eval "line=\${line_$i}"

    if [ "$logo_line" -le "$asciiLineCount" ]; then
        eval "logo=\${ascii_$logo_line}"
    else
        logo="$space"
    fi

    printf "%s %s\n" "$logo" "$line"
    i=$((i + 1))
done

