	esac
}

while [ $# -gt 0 ]; do
	case "$1" in
		--version|-v)
			echo "$version"
			exit 0
			;;
		--logo|-l)
			logooption="$2"
			shift 2
			;;
		--key|-k)
			colouroption keycolour "$2"
			shift 2
			;;
		--key2|-K)
    		colouroption keycolour2 "$2"
			shift 2
			;;
		--accent|-a)
			colouroption accentcolour "$2"
			shift 2
			;;
		--larp|-L)
			logooption="$2"
			distro="$2"
			shift 2
			;;
		--not-confused|-N)
			not_confused=1
			logooption="trash"
			distro="ubuntu"

			accentcolour="$yellow"
			keycolour="$yellow"
			keycolour2="$yellow"
			shift 1
			;;
		--confused|-C)
			randomlogo
			shift
			;;
		--help|-h)
			echo
			echo "  Usage: confetch [options]"
			echo
			echo "    -h, --help FLAG | helps you out"
			echo "    -v, --version | prints the version"
			echo "    -l, --logo NAME | well wtf do you THINK it does, huh??"
			echo "    -a, --accent COLOUR | changes your accent irl"
			echo "    -k, --key COLOUR | changes your house keys"
			echo "    -K, --key2 COLOUR | changes your other house keys"
			echo "    -C, --confused | confuses you"
			echo "    -N, --not-confused | removes all the jokes (why would you do that)"
			echo "    -L. --larp NAME | sudo W opsec. Larpity larp"
			echo
			helpoptions "$2"
			echo
			exit 0
			;;
		*)
			echo "that isnt a command buddy: $1"
			exit 1
			;;
	esac
done

