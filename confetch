# past here is where the ugly ugly magic happens. Do NOT go further unless youre me or god
# when writing this, only me and god knew what i was writing. Now only i know

colouroption() {
    case "$2" in
        red)    eval "$1=\$red" ;;
        blue)   eval "$1=\$blue" ;;
        green)  eval "$1=\$green" ;;
        yellow) eval "$1=\$yellow" ;;
        cyan)   eval "$1=\$cyan" ;;
        purple) eval "$1=\$purple" ;;
        white)  eval "$1=\$white" ;;
        *)
            echo "whats that colour: '$2'?"
            exit 1
            ;;
    esac
}

randomlogo() {
	num=$(( $(cut -d' ' -f 1 /proc/uptime | cut -d'.' -f 1) % 11 ))
			
	case "$num" in
    	0) logooption="tux" ;;
	    1) logooption="debian" ;;
	    2) logooption="void" ;;
	    3) logooption="arch" ;;
	    4) logooption="gentoo" ;;
    	5) logooption="fedora" ;;
	    6) logooption="nix" ;;
	    7) logooption="alpine" ;;
	    8) logooption="dragonfly" ;;
	    9) logooption="suse" ;;
    	*) logooption="trash" ;;
	esac
}

helpoptions() {
	case "$1" in
		logo)
			echo "  logo options:"
