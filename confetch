		;;
	*)
		distroecho="ay this isnt supported! Stop using confetch!!"
		setAutoColour "$red" "$red"
		;;
esac

for module in $enabled; do
	case " $disabled " in
		*" $module "*) continue ;;
	esac

	case "$module" in

		title)
		  titlekey="sudo apt ddos"
		  title="${bold}${accentcolour}$USER${reset}@${bold}${accentcolour}${hostname}${reset}"
		  title="   ${reset}${titlekey}${reset} ${title}"
		  addLine "$title"
		;;

		distro)
			distrokey="${distroecho}"
			distromod="${distroShort} user BTW"
			distromod="${bold}${keycolour}${distrokey}${reset} = ${distromod}"
		  	addLine "$distromod"
		;;

		wm)
		 	wm="something niche probably"
	 		case "$WAYLAND_DISPLAY" in
	    		"")
		        	server=X11
		        	wmkey="window manager"
    		    ;;
	    		*)
		         	server=Wayland
		         	wmkey="compositor"
    		    ;;
		 	esac
	 		wm="${bold}${keycolour}${wmkey}${reset} = ${wm} (${server})"
		  	addLine "$wm"
		 ;;

		shell)
			shell="${SHELL##*/}"
	 		shellkey="like.. a seashell?"
		 	shell="${bold}${keycolour}${shellkey}${reset} = ${shell}"
		 	addLine "$shell"
		;;

		kernel)
			kernel=$(uname -r )
			kernelkey="highest ranking non-General grade officer"
			kernel="${bold}${keycolour}${kernelkey}${reset} = ${kernel}"
		  	addLine "$kernel"
		;;

		uptime)
			read -r uptime _ < /proc/uptime
			uptime_seconds=${uptime%%.*}
			uptime_minutes=$(( $uptime_seconds / 60 ))
			uptime_hours=$(( $uptime_minutes / 60 ))
			if [ "$uptime_hours" -ge 10 ]; then
				uptimekey="ew get off your computer wtf. Youve been on for"
				uptime="${uptime_hours} hours"
			elif [ "$uptime_hours" -ge 5 ]; then
				uptimekey="go touch some grass, ok?"
				uptime="${uptime_hours} hours"
			elif [ "$uptime_hours" -ge 2 ]; then 
				uptimekey="get off soon, alr?"
				uptime="${uptime_hours} hours"
			elif [ "$uptime_hours" -ge 1 ]; then
				uptimekey="keep on using that computer, computer boy."
				uptime="${uptime_minutes} minutes"
			elif [ "$uptime_minutes" -ge 30 ]; then
				uptimekey="wow, not too much, huh? "
				uptime="${uptime_minutes} minutes"
			else 
				uptimekey="computah, slime this guy out. "
				uptime="${uptime_minutes} minutes"
			fi
			uptime="${bold}${keycolour}${uptimekey}${reset} ${uptime}"
		  	addLine "$uptime"
		;;

		packages)
			packages=$(
				if command -v apt-get > /dev/null 2>&1; then
		   			dpkg-query -f '.\n' -W | wc -l
				elif command -v pacman > /dev/null 2>&1; then
		   			pacman -Qq | wc -l
				elif command -v dnf > /dev/null 2>&1; then
		   			rpm -qa --queryformat '.\n' | wc -l
				elif command -v zypper > /dev/null 2>&1; then
		   			rpm -qa --queryformat '.\n' | wc -l
				elif command -v xbps-query > /dev/null 2>&1; then
					xbps-query -l | wc -l
				elif command -v emerge > /dev/null 2>&1; then
					ls /var/db/pkg/*/* -d | wc -l
				elif command -v apk > /dev/null 2>&1; then
					apk info | wc -l
				elif command -v nix-env > /dev/null 2>&1; then
					nix-env --query | wc -l
				else
		   			echo "no"
				fi
			)

			if [ "$packages" != "no" ]; then
				packages_low=$(( $packages * 10 / 12 ))
				packages_high=$(( $packages * 16 / 10 ))
				packages="prolly like ${packages_low} to ${packages_high}"
			else
				packages="stop using a niche distro ya bum"
			fi
			packageskey="aliexpress packages"
			packages="${bold}${keycolour}${packageskey}${reset} = ${packages}"
		  	addLine "$packages"
		;;

		terminal)
			case "$TERM" in
				*foot*)
					terminalkey="mghh.. feet :drooling_face: term"
					terminal="yummy in my tummy"
				;;
				*kitty*)
					terminalkey="kitty? i like them. term"
					terminal="cat"
				;;
				*rxvt-unicode*)
					terminalkey="the best x11 term btw. term"
					terminal="urxvt"
				;;
				*xterm*)
					terminalkey="why are you using this..? term"
					terminal="$TERM"
				;;
				*)
					terminalkey="prolly a bad term"
					terminal="$TERM"
				;;
			esac
			terminal="${bold}${keycolour}${terminalkey}${reset} = ${terminal}"
		  	addLine "$terminal"
		;;

		cpu)
	 		cpu=$( awk -F ': ' '/model name*:*/{print $2; exit}' /proc/cpuinfo )
		 	cpukey="cpu"
	 		cpu="${space}${bold}${keycolour}${cpukey}${reset} = ${cpu}"
		  	addLine "$cpu"
		;;

		gpu)
			if command -v lspci >/dev/null; then
   				gpuNumber=$(lspci | grep VGA | awk '{print $1; exit}')
    
				gpu=$(lspci -v -s "${gpuNumber}" | awk -F': ' '/Subsystem:/{print $2}')
				[ -z "$gpu" ] && gpu=$(lspci -mm -s "${gpuNumber}" | awk -F'"' '{print $6}' | cut -d'[' -f1)
			else
	    		gpu="you dont have one, you poor bastard"
			fi
			gpukey="gpu"
			gpu="${bold}${keycolour}${gpukey}${reset} = ${gpu}"
		  	addLine "$gpu"
		;;
		
		ram)
    		while read -r key value unit; do
		        [ "$key" = "MemTotal:" ] && { ramTotal=$value; break; }
		    done < /proc/meminfo
		    while read -r key value unit; do
        		[ "$key" = "MemAvailable:" ] && { ramAvail=$value; break; }
		    done < /proc/meminfo
		    
    		ramUsed=$(( ramTotal - ramAvail ))

    		ramTotal_GB_full=$(( ramTotal / 1000000 ))
		    ramTotal_tenth=$(( ramTotal / 100000 ))
		    ramUsed_tenth=$(( ramUsed / 100000 ))

		    ramTotal_GB="$(( ramTotal_tenth / 10 )).$(( ramTotal_tenth % 10 ))"
		    ramUsed_GB="$(( ramUsed_tenth / 10 )).$(( ramUsed_tenth % 10 ))"

			ram=$(
        		if [ "$ramTotal_GB_full" -ge 63 ]; then
					echo "${ramUsed_GB}GB/${ramTotal_GB}GB?? sharing is caring btw"
		        elif [ "$ramTotal_GB_full" -ge 31 ]; then
					echo "${ramUsed_GB}GB/${ramTotal_GB}GB, a couple browser tabs worth"
        		elif [ "$ramTotal_GB_full" -ge 15 ]; then
					echo "${ramUsed_GB}GB/${ramTotal_GB}GB, pretty average tbh"
        		elif [ "$ramTotal_GB_full" -ge 7 ]; then
					echo "${ramUsed_GB}GB/${ramTotal_GB}GB, you better hope GTA 6 never releases"
				else
					echo "only ${ramUsed_GB}GB/${ramTotal_GB}GB..? treat yourself, please"
				fi
			)
    		ramkey="ai food"
    		ram="${bold}${keycolour}${ramkey}${reset} = ${ram}"
    		addLine "$ram"
    		;;

	esac
done

